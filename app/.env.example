EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — analytics + crash reporting. App works without these.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat SDK keys (per platform, from app.revenuecat.com → Project → Apps).
# When these are empty the paywall keeps its placeholder behavior and
# restorePurchases() no-ops — safe for Expo Go and unconfigured builds.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
